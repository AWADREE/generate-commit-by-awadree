{
  "name": "generate-commit-by-codex",
  "displayName": "Generate Commit by Codex",
  "description": "Generate a commit message from Git changes with Codex and place it in the VS Code Source Control input.",
  "version": "0.1.0",
  "publisher": "zoldy",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Source Control",
    "Other"
  ],
  "keywords": [
    "codex",
    "git",
    "commit",
    "commit message",
    "source control"
  ],
  "galleryBanner": {
    "color": "#111827",
    "theme": "dark"
  },
  "activationEvents": [
    "onCommand:codexCommit.generateCommitMessage",
    "onCommand:codexCommit.signIn",
    "onCommand:codexCommit.signOut",
    "onCommand:codexCommit.reauthenticate"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codexCommit.generateCommitMessage",
        "title": "Generate Commit Message by Codex",
        "category": "Generate Commit by Codex",
        "icon": {
          "light": "assets/codex-commit-light.svg",
          "dark": "assets/codex-commit-dark.svg"
        }
      },
      {
        "command": "codexCommit.signIn",
        "title": "Generate Commit by Codex: Sign In to Codex",
        "category": "Generate Commit by Codex"
      },
      {
        "command": "codexCommit.signOut",
        "title": "Generate Commit by Codex: Sign Out of Codex",
        "category": "Generate Commit by Codex"
      },
      {
        "command": "codexCommit.reauthenticate",
        "title": "Generate Commit by Codex: Reauthenticate Codex",
        "category": "Generate Commit by Codex"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "codexCommit.generateCommitMessage",
          "when": "scmProvider == git",
          "group": "navigation@-2"
        },
        {
          "submenu": "codexCommit/scm/title",
          "when": "scmProvider == git",
          "group": "navigation@-1"
        }
      ],
      "scm/repository": [
        {
          "command": "codexCommit.generateCommitMessage",
          "when": "scmProvider == git",
          "group": "navigation@1"
        }
      ],
      "scm/sourceControl": [
        {
          "command": "codexCommit.generateCommitMessage",
          "when": "scmProvider == git",
          "group": "navigation@1"
        }
      ],
      "codexCommit/scm/title": [
        {
          "command": "codexCommit.generateCommitMessage",
          "when": "scmProvider == git",
          "group": "navigation@1"
        },
        {
          "command": "codexCommit.signIn",
          "group": "2_auth@1"
        },
        {
          "command": "codexCommit.reauthenticate",
          "group": "2_auth@2"
        },
        {
          "command": "codexCommit.signOut",
          "group": "2_auth@3"
        }
      ],
      "commandPalette": [
        {
          "command": "codexCommit.generateCommitMessage"
        },
        {
          "command": "codexCommit.signIn"
        },
        {
          "command": "codexCommit.signOut"
        },
        {
          "command": "codexCommit.reauthenticate"
        }
      ]
    },
    "submenus": [
      {
        "id": "codexCommit/scm/title",
        "label": "Generate Commit Message by Codex"
      }
    ],
    "configuration": {
      "title": "Generate Commit by Codex",
      "properties": {
        "codexCommit.customInstructions": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional extra instructions appended to the Codex commit message prompt."
        },
        "codexCommit.maxDiffChars": {
          "type": "number",
          "default": 60000,
          "minimum": 4000,
          "maximum": 200000,
          "markdownDescription": "Maximum number of diff characters sent to Codex before safe truncation."
        },
        "codexCommit.codexCommand": {
          "type": "string",
          "default": "codex",
          "markdownDescription": "Codex CLI executable to run. Change only if Codex is not on PATH."
        }
      }
    }
  },
  "scripts": {
    "clean": "rimraf dist out",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:extension": "node ./test/run-extension-host.js",
    "verify": "npm run compile && npm run test:unit && npm run test:extension",
    "vscode:prepublish": "npm run compile",
    "package:vsix": "node -e \"require('fs').mkdirSync('out',{recursive:true})\" && vsce package --allow-missing-repository --out out/generate-commit-by-codex-0.1.0.vsix",
    "install:vsix": "npm run package:vsix && code --install-extension out/generate-commit-by-codex-0.1.0.vsix --force",
    "publish:dry-run": "node -e \"require('fs').mkdirSync('out',{recursive:true})\" && vsce package --allow-missing-repository --out out/generate-commit-by-codex-0.1.0.vsix",
    "publish:marketplace": "vsce publish --allow-missing-repository --packagePath out/generate-commit-by-codex-0.1.0.vsix --skip-duplicate"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "rimraf": "^5.0.7",
    "typescript": "^5.5.3",
    "vitest": "^4.1.8"
  }
}
