{
  "name": "generate-commit-by-awadree",
  "displayName": "Generate Commit by Awadree (Unofficial)",
  "description": "Unofficial extension that generates a Git commit message from local changes using the Codex CLI.",
  "version": "0.1.6",
  "publisher": "Awadree",
  "license": "MIT",
  "icon": "assets/extension-icon.png",
  "markdown": "github",
  "pricing": "Free",
  "repository": {
    "type": "git",
    "url": "https://github.com/Awadree/generate-commit-by-awadree.git"
  },
  "homepage": "https://github.com/Awadree/generate-commit-by-awadree#readme",
  "bugs": {
    "url": "https://github.com/Awadree/generate-commit-by-awadree/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "codex",
    "git",
    "commit",
    "commit message",
    "source control",
    "conventional commits",
    "ai"
  ],
  "galleryBanner": {
    "color": "#16243D",
    "theme": "dark"
  },
  "activationEvents": [
    "onCommand:codexCommit.generateCommitMessage",
    "onCommand:codexCommit.selectModel",
    "onCommand:codexCommit.selectReasoningEffort",
    "onCommand:codexCommit.signIn",
    "onCommand:codexCommit.signOut",
    "onCommand:codexCommit.reauthenticate"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codexCommit.generateCommitMessage",
        "title": "Generate Commit Message by Awadree",
        "category": "Generate Commit by Awadree",
        "icon": {
          "light": "assets/commit-spark-light.svg",
          "dark": "assets/commit-spark-dark.svg"
        }
      },
      {
        "command": "codexCommit.selectModel",
        "title": "Generate Commit by Awadree: Select Model",
        "category": "Generate Commit by Awadree"
      },
      {
        "command": "codexCommit.selectReasoningEffort",
        "title": "Generate Commit by Awadree: Select Reasoning Effort",
        "category": "Generate Commit by Awadree"
      },
      {
        "command": "codexCommit.signIn",
        "title": "Generate Commit by Awadree: Sign In",
        "category": "Generate Commit by Awadree"
      },
      {
        "command": "codexCommit.signOut",
        "title": "Generate Commit by Awadree: Sign Out",
        "category": "Generate Commit by Awadree"
      },
      {
        "command": "codexCommit.reauthenticate",
        "title": "Generate Commit by Awadree: Reauthenticate",
        "category": "Generate Commit by Awadree"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "codexCommit.generateCommitMessage",
          "when": "scmProvider == git",
          "group": "navigation@-2"
        }
      ],
      "commandPalette": [
        {
          "command": "codexCommit.generateCommitMessage"
        },
        {
          "command": "codexCommit.selectModel"
        },
        {
          "command": "codexCommit.selectReasoningEffort"
        },
        {
          "command": "codexCommit.signIn"
        },
        {
          "command": "codexCommit.signOut"
        },
        {
          "command": "codexCommit.reauthenticate"
        }
      ]
    },
    "configuration": {
      "title": "Generate Commit by Awadree",
      "properties": {
        "codexCommit.customInstructions": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional extra instructions appended to the Codex commit message prompt."
        },
        "codexCommit.maxDiffChars": {
          "type": "number",
          "default": 60000,
          "minimum": 4000,
          "maximum": 200000,
          "markdownDescription": "Maximum number of diff characters sent to Codex before safe truncation."
        },
        "codexCommit.codexCommand": {
          "type": "string",
          "default": "codex",
          "markdownDescription": "Codex CLI executable to run. Change only if Codex is not on PATH."
        },
        "codexCommit.model": {
          "type": "string",
          "default": "gpt-5.4-mini",
          "enum": [
            "",
            "gpt-5.4-mini",
            "gpt-5.5",
            "gpt-5.4",
            "gpt-5.3-codex-spark"
          ],
          "enumItemLabels": [
            "Use extension default",
            "GPT-5.4 Mini",
            "GPT-5.5",
            "GPT-5.4",
            "GPT-5.3 Codex Spark"
          ],
          "markdownDescription": "Codex model used only by this extension when generating commit messages. Empty or unsupported saved values fall back to the extension default."
        },
        "codexCommit.reasoningEffort": {
          "type": "string",
          "default": "low",
          "enum": [
            "",
            "low",
            "medium",
            "high"
          ],
          "enumItemLabels": [
            "Use extension default",
            "Low",
            "Medium",
            "High"
          ],
          "markdownDescription": "Codex reasoning effort used only by this extension when generating commit messages. Empty or unsupported saved values fall back to the extension default."
        }
      }
    }
  },
  "scripts": {
    "clean": "rimraf dist out",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:extension": "node ./test/run-extension-host.js",
    "verify": "npm run compile && npm run test:unit && npm run test:extension",
    "vscode:prepublish": "npm run compile",
    "package:vsix": "node -e \"require('fs').mkdirSync('out',{recursive:true})\" && vsce package --baseContentUrl https://github.com/Awadree/generate-commit-by-awadree/blob/main/ --baseImagesUrl https://raw.githubusercontent.com/Awadree/generate-commit-by-awadree/main/ --out out/generate-commit-by-awadree-0.1.6.vsix",
    "install:vsix": "npm run package:vsix && code --install-extension out/generate-commit-by-awadree-0.1.6.vsix --force",
    "publish:dry-run": "node -e \"require('fs').mkdirSync('out',{recursive:true})\" && vsce package --baseContentUrl https://github.com/Awadree/generate-commit-by-awadree/blob/main/ --baseImagesUrl https://raw.githubusercontent.com/Awadree/generate-commit-by-awadree/main/ --out out/generate-commit-by-awadree-0.1.6.vsix",
    "publish:marketplace": "vsce publish --packagePath out/generate-commit-by-awadree-0.1.6.vsix --skip-duplicate"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "rimraf": "^5.0.7",
    "typescript": "^5.5.3",
    "vitest": "^4.1.8"
  }
}
